/* ═══════════════════════════════════════════════════════════════
   Q-ARunner — queue.css
   Sortable run queue styles.
   Place at: static/css/queue.css
   Link AFTER style.css in <head>.
═══════════════════════════════════════════════════════════════ */

/* ══════════════════════════════
   RUN QUEUE CONTAINER
══════════════════════════════ */
#run-queue-list {
  display: flex;
  flex-direction: column;
  gap: 7px;
}

/* ══════════════════════════════
   QUEUE ITEM — 4-column grid
   [handle] [priority] [body] [chip]
══════════════════════════════ */
.q-item {
  display: grid;
  grid-template-columns: 22px 22px 1fr auto;
  align-items: center;
  gap: 10px;
  padding: 9px 13px;
  background: var(--glass-1);
  border: 1px solid var(--glass-border);
  border-radius: var(--r);
  transition: var(--trans), box-shadow 0.15s, transform 0.15s;
  box-shadow: var(--shadow-sm);
  cursor: default;
  user-select: none;
}

/* Hover lift — not while sorting */
.q-item:not(.sortable-drag):not(.sortable-chosen):hover {
  transform: translateY(-1px);
  box-shadow: var(--shadow-md);
}

/* Colour variants */
.q-item.q-active         { background: var(--accent-soft);  border-color: var(--accent-25);  }
.q-item.q-active-violet  { background: var(--violet-soft);  border-color: var(--violet-25);  }
.q-item.q-active-emerald { background: var(--emerald-soft); border-color: var(--emerald-25);  }

/* ── Drag handle ── */
.q-drag-handle {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--t4);
  cursor: grab;
  font-size: 14px;
  line-height: 1;
  padding: 2px 1px;
  border-radius: 4px;
  transition: color 0.15s, background 0.15s;
  flex-shrink: 0;
  letter-spacing: -1px;
}
.q-drag-handle:hover  { color: var(--t2); background: var(--glass-3); }
.q-drag-handle:active { cursor: grabbing; color: var(--accent); }

/* ── Priority badge ── */
.q-priority {
  width: 20px; height: 20px;
  border-radius: 6px;
  background: var(--glass-3);
  border: 1px solid var(--glass-border-dim);
  display: grid; place-items: center;
  font-family: var(--font-mono); font-size: 9px; font-weight: 700;
  color: var(--t3);
  transition: var(--trans); flex-shrink: 0;
}
.q-item.q-active         .q-priority { background: var(--accent-soft);  border-color: var(--accent-30);  color: var(--accent);  }
.q-item.q-active-violet  .q-priority { background: var(--violet-soft);  border-color: var(--violet-30);  color: var(--violet);  }
.q-item.q-active-emerald .q-priority { background: var(--emerald-soft); border-color: var(--emerald-30);  color: var(--emerald); }

/* ── Item body ── */
.q-item-body { display: flex; align-items: center; gap: 9px; min-width: 0; }
.q-icon { font-size: 15px; flex-shrink: 0; }
.q-name {
  flex: 1;
  font-size: 12.5px; font-weight: 600; color: var(--t2);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  transition: color 0.15s;
}
.q-item.q-active .q-name,
.q-item.q-active-violet .q-name,
.q-item.q-active-emerald .q-name { color: var(--t0); }

/* ── Status chip ── */
.q-chip {
  font-family: var(--font-mono); font-size: 8px;
  padding: 3px 10px; border-radius: 10px;
  border: 1px solid var(--glass-border-dim);
  color: var(--t4); text-transform: uppercase;
  background: var(--glass-3); white-space: nowrap; flex-shrink: 0;
}
.q-item.q-active         .q-chip { border-color: var(--accent-glow); color: var(--accent);  background: var(--accent-soft);  }
.q-item.q-active-violet  .q-chip { border-color: var(--violet-glow); color: var(--violet);  background: var(--violet-soft);  }
.q-item.q-active-emerald .q-chip { border-color: var(--emerald-glow); color: var(--emerald); background: var(--emerald-soft); }

/* ══════════════════════════════
   SORTABLEJS DRAG STATES
══════════════════════════════ */
.sortable-ghost {
  opacity: 0.28;
  background: var(--glass-3) !important;
  border-style: dashed !important;
  border-color: var(--glass-border) !important;
  box-shadow: none !important;
  transform: none !important;
}
.sortable-chosen {
  box-shadow: 0 16px 48px var(--accent-24), var(--shadow-lg) !important;
  border-color: var(--accent-glow) !important;
  transform: scale(1.02) rotate(0.5deg) !important;
  z-index: 999;
  cursor: grabbing;
}
.sortable-drag { opacity: 1 !important; }

/* ══════════════════════════════
   PRIORITY POP ANIMATION
══════════════════════════════ */
@keyframes priorityPop {
  0%   { transform: scale(1.5);  }
  55%  { transform: scale(0.88); }
  80%  { transform: scale(1.08); }
  100% { transform: scale(1);    }
}
.q-priority.pop {
  animation: priorityPop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

/* ══════════════════════════════
   QUEUE CARD HEADER HINT
══════════════════════════════ */
.queue-hint {
  font-family: var(--font-mono); font-size: 8px;
  color: var(--t4); display: flex; align-items: center;
  gap: 5px; letter-spacing: .05em;
}
.queue-hint-dot {
  width: 4px; height: 4px; border-radius: 50%;
  background: var(--t4); flex-shrink: 0;
}

/* ══════════════════════════════
   EMPTY STATE
══════════════════════════════ */
.rq-empty {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 9px; padding: 26px 16px; text-align: center;
}
.rq-empty-icon  { font-size: 26px; opacity: .4; }
.rq-empty-title {
  font-family: var(--font-mono); font-size: 8.5px;
  letter-spacing: .2em; text-transform: uppercase; color: var(--t3);
}
.rq-empty-hint  { font-size: 11.5px; color: var(--t4); line-height: 1.5; }


/* ════════════════════════════════════════════════════════════════
   SIDEBAR ITEM STATES — Enabled / Disabled
   Applied by syncSidebarState() in queue.js whenever any
   module toggle or group switch changes.
════════════════════════════════════════════════════════════════ */

/* ── BASE: all sub-rows get a smooth transition ── */
.sb-sub {
  transition:
    background   0.22s cubic-bezier(0.4,0,0.2,1),
    border-color 0.22s cubic-bezier(0.4,0,0.2,1),
    opacity      0.22s cubic-bezier(0.4,0,0.2,1),
    filter       0.22s cubic-bezier(0.4,0,0.2,1),
    box-shadow   0.22s cubic-bezier(0.4,0,0.2,1);
}

/* ════════════════════════════════════════════════
   ENABLED / DISABLED sidebar item states
   Higher specificity than .sb-sub.active so these
   always win regardless of selection state.
════════════════════════════════════════════════ */

/* ─── BASE: smooth transitions on every sub-row ─── */
.sb-sub {
  transition: var(--trans);
}

/* ══════════════════════════════════════
   ENABLED — Q Audit (indigo bg · red glow)
══════════════════════════════════════ */
.sb-sub.mod-enabled,
.sb-sub.mod-enabled.active,
.sb-sub.mod-enabled:hover {
  background: linear-gradient(
    110deg,
    var(--accent-25) 0%,
    var(--accent-15) 45%,
    var(--accent-05) 100%
  ) !important;
  border-top:    1px solid var(--accent-30) !important;
  border-right:  1px solid var(--accent-30) !important;
  border-bottom: 1px solid var(--accent-30) !important;
  border-left:   3px solid var(--accent)    !important;
  box-shadow:
    inset 4px 0 16px var(--accent-22),
    inset 0  1px 0   var(--white-12),
    0 0 12px var(--rose-25),
    0 2px 18px var(--rose-20),
    0 4px  8px var(--rose-10) !important;
  opacity:      1    !important;
  filter:       none !important;
  padding-left: 9px;
}
.sb-sub.mod-enabled::before,
.sb-sub.mod-enabled.active::before { display: none !important; }

.sb-sub.mod-enabled .sb-sub-icon,
.sb-sub.mod-enabled.active .sb-sub-icon {
  opacity: 1 !important;
  filter: drop-shadow(0 0 6px var(--accent-60)) !important;
}
.sb-sub.mod-enabled .sb-sub-nm,
.sb-sub.mod-enabled.active .sb-sub-nm {
  color:       var(--accent) !important;
  font-weight: 700 !important;
}

/* ══════════════════════════════════════
   ENABLED — Audit Plan (violet bg · red glow)
══════════════════════════════════════ */
.sb-sub.audit-sub.mod-enabled,
.sb-sub.audit-sub.mod-enabled.active,
.sb-sub.audit-sub.mod-enabled:hover {
  background: linear-gradient(
    110deg,
    var(--violet-25) 0%,
    var(--violet-15) 45%,
    var(--violet-05) 100%
  ) !important;
  border-top:    1px solid var(--violet-30) !important;
  border-right:  1px solid var(--violet-30) !important;
  border-bottom: 1px solid var(--violet-30) !important;
  border-left:   3px solid var(--violet)    !important;
  box-shadow:
    inset 4px 0 16px var(--violet-22),
    inset 0  1px 0   var(--white-12),
    0 0 12px var(--rose-25),
    0 2px 18px var(--rose-20),
    0 4px  8px var(--rose-10) !important;
}
.sb-sub.audit-sub.mod-enabled::before,
.sb-sub.audit-sub.mod-enabled.active::before { display: none !important; }
.sb-sub.audit-sub.mod-enabled .sb-sub-icon,
.sb-sub.audit-sub.mod-enabled.active .sb-sub-icon {
  opacity: 1 !important;
  filter: drop-shadow(0 0 6px var(--violet-60)) !important;
}
.sb-sub.audit-sub.mod-enabled .sb-sub-nm,
.sb-sub.audit-sub.mod-enabled.active .sb-sub-nm {
  color: var(--violet) !important;
  font-weight: 700 !important;
}

/* ══════════════════════════════════════
   ENABLED — Inventory (emerald bg · red glow)
══════════════════════════════════════ */
.sb-sub.inv-sub.mod-enabled,
.sb-sub.inv-sub.mod-enabled.active,
.sb-sub.inv-sub.mod-enabled:hover {
  background: linear-gradient(
    110deg,
    var(--emerald-25) 0%,
    var(--emerald-14) 45%,
    var(--emerald-04) 100%
  ) !important;
  border-top:    1px solid var(--emerald-30) !important;
  border-right:  1px solid var(--emerald-30) !important;
  border-bottom: 1px solid var(--emerald-30) !important;
  border-left:   3px solid var(--emerald)    !important;
  box-shadow:
    inset 4px 0 16px var(--emerald-20),
    inset 0  1px 0   var(--white-12),
    0 0 12px var(--rose-25),
    0 2px 18px var(--rose-20),
    0 4px  8px var(--rose-10) !important;
}
.sb-sub.inv-sub.mod-enabled::before,
.sb-sub.inv-sub.mod-enabled.active::before { display: none !important; }
.sb-sub.inv-sub.mod-enabled .sb-sub-icon,
.sb-sub.inv-sub.mod-enabled.active .sb-sub-icon {
  opacity: 1 !important;
  filter: drop-shadow(0 0 6px var(--emerald-60)) !important;
}
.sb-sub.inv-sub.mod-enabled .sb-sub-nm,
.sb-sub.inv-sub.mod-enabled.active .sb-sub-nm {
  color: var(--emerald) !important;
  font-weight: 700 !important;
}

/* ══════════════════════════════════════
   DISABLED — all groups
   Faded · greyed · no hover · no bar
══════════════════════════════════════ */
.sb-sub.mod-disabled {
  opacity:      0.28        !important;
  filter:       grayscale(70%) brightness(0.65) !important;
  background:   transparent !important;
  border:       1px solid transparent !important;
  box-shadow:   none        !important;
  transform:    none        !important;
  cursor:       not-allowed !important;
  padding-left: 10px;
}
.sb-sub.mod-disabled::before { display: none !important; }
.sb-sub.mod-disabled:hover,
.sb-sub.mod-disabled.active {
  background: transparent !important;
  border:     1px solid transparent !important;
  box-shadow: none !important;
  filter:     grayscale(70%) brightness(0.65) !important;
  opacity:    0.28 !important;
  transform:  none !important;
}
.sb-sub.mod-disabled .sb-sub-nm,
.sb-sub.mod-disabled .sb-sub-icon { color: inherit !important; filter: none !important; }

/* ══════════════════════════════════════
   GROUP HEADERS — enabled
══════════════════════════════════════ */
.sb-grp-hd { transition: var(--trans); }

.sb-grp-hd.grp-enabled {
  background:   linear-gradient(110deg, var(--accent-15) 0%, var(--accent-03) 100%);
  border-color: var(--accent-30);
  box-shadow:   inset 0 1px 0 var(--white-08), 0 2px 10px var(--rose-15);
}
.sb-grp-hd.grp-enabled .sb-grp-icon {
  background:   var(--accent-20);
  border-color: var(--accent-30);
  box-shadow:   0 0 10px var(--rose-20);
}
.sb-grp-hd.grp-enabled .sb-grp-name { color: var(--t0); font-weight: 800; }

.sb-grp-hd.audit-hd.grp-enabled {
  background:   linear-gradient(110deg, var(--violet-15) 0%, var(--violet-03) 100%);
  border-color: var(--violet-30);
  box-shadow:   inset 0 1px 0 var(--white-08), 0 2px 10px var(--rose-15);
}
.sb-grp-hd.audit-hd.grp-enabled .sb-grp-icon {
  background:   var(--violet-20);
  border-color: var(--violet-30);
  box-shadow:   0 0 10px var(--rose-20);
}
.sb-grp-hd.audit-hd.grp-enabled .sb-grp-name { color: var(--t0); font-weight: 800; }

.sb-grp-hd.inv-hd.grp-enabled {
  background:   linear-gradient(110deg, var(--emerald-14) 0%, var(--emerald-03) 100%);
  border-color: var(--emerald-30);
  box-shadow:   inset 0 1px 0 var(--white-08), 0 2px 10px var(--rose-15);
}
.sb-grp-hd.inv-hd.grp-enabled .sb-grp-icon {
  background:   var(--emerald-18);
  border-color: var(--emerald-30);
  box-shadow:   0 0 10px var(--rose-20);
}
.sb-grp-hd.inv-hd.grp-enabled .sb-grp-name { color: var(--t0); font-weight: 800; }

/* GROUP HEADERS — disabled */
.sb-grp-hd.grp-disabled {
  opacity: 0.45;
  filter:  grayscale(40%);
}
.sb-grp-hd.grp-disabled .sb-grp-icon { filter: grayscale(50%); }

/* ══════════════════════════════════════
   ENABLE PULSE — one-shot burst on first toggle
══════════════════════════════════════ */
@keyframes sbEnablePulse {
  0%   { box-shadow: inset 4px 0 0 var(--accent-60), 0 0 0 0 var(--rose-40); }
  55%  { box-shadow: inset 4px 0 16px var(--accent-30), 0 0 14px var(--rose-15); }
  100% { box-shadow: inset 4px 0 16px var(--accent-22), inset 0 1px 0 var(--white-12), 0 0 12px var(--rose-25), 0 2px 18px var(--rose-20); }
}
@keyframes sbEnablePulseViolet {
  0%   { box-shadow: inset 4px 0 0 var(--violet-60), 0 0 0 0 var(--rose-40); }
  55%  { box-shadow: inset 4px 0 16px var(--violet-30), 0 0 14px var(--rose-15); }
  100% { box-shadow: inset 4px 0 16px var(--violet-22), inset 0 1px 0 var(--white-12), 0 0 12px var(--rose-25), 0 2px 18px var(--rose-20); }
}
@keyframes sbEnablePulseEmerald {
  0%   { box-shadow: inset 4px 0 0 var(--emerald-60), 0 0 0 0 var(--rose-40); }
  55%  { box-shadow: inset 4px 0 16px var(--emerald-30), 0 0 14px var(--rose-15); }
  100% { box-shadow: inset 4px 0 16px var(--emerald-20), inset 0 1px 0 var(--white-12), 0 0 12px var(--rose-25), 0 2px 18px var(--rose-20); }
}
.sb-sub.mod-enabled.just-enabled           { animation: sbEnablePulse        0.5s ease forwards; }
.sb-sub.audit-sub.mod-enabled.just-enabled { animation: sbEnablePulseViolet  0.5s ease forwards; }
.sb-sub.inv-sub.mod-enabled.just-enabled   { animation: sbEnablePulseEmerald 0.5s ease forwards; }

/* ════════════════════════════════════════════════
   NEW GROUP STATES — Ad-hoc / Ongoing / Location / Import
   Amber · Sky · Cyan · Lime
   Appended after existing 3 group styles.
   Same pattern: enabled gets gradient + red glow,
   disabled gets faded/greyscale.
════════════════════════════════════════════════ */

/* ── ENABLED sub rows ── */

/* Ad-hoc Audit — amber */
.sb-sub.adhoc-sub.mod-enabled,
.sb-sub.adhoc-sub.mod-enabled.active,
.sb-sub.adhoc-sub.mod-enabled:hover {
  background: linear-gradient(110deg, var(--amber-25) 0%, var(--amber-15) 45%, var(--amber-10) 100%) !important;
  border-top:    1px solid var(--amber-30) !important;
  border-right:  1px solid var(--amber-30) !important;
  border-bottom: 1px solid var(--amber-30) !important;
  border-left:   3px solid var(--amber)    !important;
  box-shadow:
    inset 4px 0 16px var(--amber-20),
    inset 0  1px 0   var(--white-12),
    0 0  12px var(--rose-25),
    0 2px 18px var(--rose-20),
    0 4px  8px var(--rose-10) !important;
}
.sb-sub.adhoc-sub.mod-enabled::before,
.sb-sub.adhoc-sub.mod-enabled.active::before { display: none !important; }
.sb-sub.adhoc-sub.mod-enabled .sb-sub-icon,
.sb-sub.adhoc-sub.mod-enabled.active .sb-sub-icon { opacity:1!important; filter:drop-shadow(0 0 6px var(--amber-60))!important; }
.sb-sub.adhoc-sub.mod-enabled .sb-sub-nm,
.sb-sub.adhoc-sub.mod-enabled.active .sb-sub-nm   { color:var(--amber)!important; font-weight:700!important; }

/* Ongoing Audit — sky */
.sb-sub.ongo-sub.mod-enabled,
.sb-sub.ongo-sub.mod-enabled.active,
.sb-sub.ongo-sub.mod-enabled:hover {
  background: linear-gradient(110deg, var(--sky-25) 0%, var(--sky-15) 45%, var(--sky-10) 100%) !important;
  border-top:    1px solid var(--sky-30) !important;
  border-right:  1px solid var(--sky-30) !important;
  border-bottom: 1px solid var(--sky-30) !important;
  border-left:   3px solid var(--sky)    !important;
  box-shadow:
    inset 4px 0 16px var(--sky-20),
    inset 0  1px 0   var(--white-12),
    0 0  12px var(--rose-25),
    0 2px 18px var(--rose-20),
    0 4px  8px var(--rose-10) !important;
}
.sb-sub.ongo-sub.mod-enabled::before,
.sb-sub.ongo-sub.mod-enabled.active::before { display: none !important; }
.sb-sub.ongo-sub.mod-enabled .sb-sub-icon,
.sb-sub.ongo-sub.mod-enabled.active .sb-sub-icon { opacity:1!important; filter:drop-shadow(0 0 6px var(--sky-60))!important; }
.sb-sub.ongo-sub.mod-enabled .sb-sub-nm,
.sb-sub.ongo-sub.mod-enabled.active .sb-sub-nm   { color:var(--sky)!important; font-weight:700!important; }

/* Location Setup — cyan */
.sb-sub.loc-sub.mod-enabled,
.sb-sub.loc-sub.mod-enabled.active,
.sb-sub.loc-sub.mod-enabled:hover {
  background: linear-gradient(110deg, var(--cyan-25) 0%, var(--cyan-15) 45%, var(--cyan-10) 100%) !important;
  border-top:    1px solid var(--cyan-30) !important;
  border-right:  1px solid var(--cyan-30) !important;
  border-bottom: 1px solid var(--cyan-30) !important;
  border-left:   3px solid var(--cyan)    !important;
  box-shadow:
    inset 4px 0 16px var(--cyan-20),
    inset 0  1px 0   var(--white-12),
    0 0  12px var(--rose-25),
    0 2px 18px var(--rose-20),
    0 4px  8px var(--rose-10) !important;
}
.sb-sub.loc-sub.mod-enabled::before,
.sb-sub.loc-sub.mod-enabled.active::before { display: none !important; }
.sb-sub.loc-sub.mod-enabled .sb-sub-icon,
.sb-sub.loc-sub.mod-enabled.active .sb-sub-icon { opacity:1!important; filter:drop-shadow(0 0 6px var(--cyan-60))!important; }
.sb-sub.loc-sub.mod-enabled .sb-sub-nm,
.sb-sub.loc-sub.mod-enabled.active .sb-sub-nm   { color:var(--cyan)!important; font-weight:700!important; }

/* Import App — lime */
.sb-sub.imp-sub.mod-enabled,
.sb-sub.imp-sub.mod-enabled.active,
.sb-sub.imp-sub.mod-enabled:hover {
  background: linear-gradient(110deg, var(--lime-25) 0%, var(--lime-15) 45%, var(--lime-10) 100%) !important;
  border-top:    1px solid var(--lime-30) !important;
  border-right:  1px solid var(--lime-30) !important;
  border-bottom: 1px solid var(--lime-30) !important;
  border-left:   3px solid var(--lime)    !important;
  box-shadow:
    inset 4px 0 16px var(--lime-20),
    inset 0  1px 0   var(--white-12),
    0 0  12px var(--rose-25),
    0 2px 18px var(--rose-20),
    0 4px  8px var(--rose-10) !important;
}
.sb-sub.imp-sub.mod-enabled::before,
.sb-sub.imp-sub.mod-enabled.active::before { display: none !important; }
.sb-sub.imp-sub.mod-enabled .sb-sub-icon,
.sb-sub.imp-sub.mod-enabled.active .sb-sub-icon { opacity:1!important; filter:drop-shadow(0 0 6px var(--lime-60))!important; }
.sb-sub.imp-sub.mod-enabled .sb-sub-nm,
.sb-sub.imp-sub.mod-enabled.active .sb-sub-nm   { color:var(--lime)!important; font-weight:700!important; }

/* ── ENABLED group headers ── */

/* Ad-hoc group header — amber */
.sb-grp-hd.adhoc-hd.grp-enabled {
  background: linear-gradient(110deg, var(--amber-15) 0%, var(--amber-10) 100%);
  border-color: var(--amber-30);
  box-shadow: inset 0 1px 0 var(--white-08), 0 2px 10px var(--rose-15);
}
.sb-grp-hd.adhoc-hd.grp-enabled .sb-grp-icon { background:var(--amber-20); border-color:var(--amber-30); box-shadow:0 0 10px var(--rose-20); }
.sb-grp-hd.adhoc-hd.grp-enabled .sb-grp-name { color:var(--t0); font-weight:800; }

/* Ongoing group header — sky */
.sb-grp-hd.ongo-hd.grp-enabled {
  background: linear-gradient(110deg, var(--sky-15) 0%, var(--sky-10) 100%);
  border-color: var(--sky-30);
  box-shadow: inset 0 1px 0 var(--white-08), 0 2px 10px var(--rose-15);
}
.sb-grp-hd.ongo-hd.grp-enabled .sb-grp-icon { background:var(--sky-20); border-color:var(--sky-30); box-shadow:0 0 10px var(--rose-20); }
.sb-grp-hd.ongo-hd.grp-enabled .sb-grp-name { color:var(--t0); font-weight:800; }

/* Location group header — cyan */
.sb-grp-hd.loc-hd.grp-enabled {
  background: linear-gradient(110deg, var(--cyan-15) 0%, var(--cyan-10) 100%);
  border-color: var(--cyan-30);
  box-shadow: inset 0 1px 0 var(--white-08), 0 2px 10px var(--rose-15);
}
.sb-grp-hd.loc-hd.grp-enabled .sb-grp-icon { background:var(--cyan-20); border-color:var(--cyan-30); box-shadow:0 0 10px var(--rose-20); }
.sb-grp-hd.loc-hd.grp-enabled .sb-grp-name { color:var(--t0); font-weight:800; }

/* Import group header — lime */
.sb-grp-hd.imp-hd.grp-enabled {
  background: linear-gradient(110deg, var(--lime-15) 0%, var(--lime-10) 100%);
  border-color: var(--lime-30);
  box-shadow: inset 0 1px 0 var(--white-08), 0 2px 10px var(--rose-15);
}
.sb-grp-hd.imp-hd.grp-enabled .sb-grp-icon { background:var(--lime-20); border-color:var(--lime-30); box-shadow:0 0 10px var(--rose-20); }
.sb-grp-hd.imp-hd.grp-enabled .sb-grp-name { color:var(--t0); font-weight:800; }

/* ── New group queue item variants ── */
.q-item.q-active-amber  { background: var(--amber-soft);  border-color: var(--amber-25);  }
.q-item.q-active-sky    { background: var(--sky-soft);    border-color: var(--sky-25);    }
.q-item.q-active-cyan   { background: var(--cyan-soft);   border-color: var(--cyan-25);   }
.q-item.q-active-lime   { background: var(--lime-soft);   border-color: var(--lime-25);   }

.q-item.q-active-amber .q-priority { background: var(--amber-20); border-color: var(--amber-30); color: var(--amber); }
.q-item.q-active-sky   .q-priority { background: var(--sky-20);   border-color: var(--sky-30);   color: var(--sky);   }
.q-item.q-active-cyan  .q-priority { background: var(--cyan-20);  border-color: var(--cyan-30);  color: var(--cyan);  }
.q-item.q-active-lime  .q-priority { background: var(--lime-20);  border-color: var(--lime-30);  color: var(--lime);  }

.q-item.q-active-amber .q-chip { border-color: var(--amber-25); color: var(--amber); background: var(--amber-soft); }
.q-item.q-active-sky   .q-chip { border-color: var(--sky-25);   color: var(--sky);   background: var(--sky-soft);   }
.q-item.q-active-cyan  .q-chip { border-color: var(--cyan-25);  color: var(--cyan);  background: var(--cyan-soft);  }
.q-item.q-active-lime  .q-chip { border-color: var(--lime-25);  color: var(--lime);  background: var(--lime-soft);  }

.q-item.q-active-amber .q-name,
.q-item.q-active-sky   .q-name,
.q-item.q-active-cyan  .q-name,
.q-item.q-active-lime  .q-name { color: var(--t0); }

/* ── Unified Audit page: section transition ── */
#audit-plan-sections,
#adhoc-sections {
  transition: opacity 0.22s var(--trans), transform 0.22s var(--trans);
}
#adhoc-sections[style*="display: none"],
#audit-plan-sections[style*="display: none"] {
  opacity: 0;
  pointer-events: none;
}